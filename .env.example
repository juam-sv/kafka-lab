# Kafka Broker Configuration
KAFKA_BROKER=broker:9092
MSG_PER_SEC=5
USE_MESSAGE_KEY=false

# Consumer Configuration
CONSUMER_GROUP=finance-group
MAX_MSG_PER_SEC=0

# Oracle Database Configuration (local Docker)
ORACLE_SYS_PASSWORD=SysPass123
DB_USER=finance_user
DB_PASSWORD=Finance123
DB_DSN=oracle:1521/XEPDB1

# Cache Configuration
CACHE_HOST=valkey
CACHE_PORT=6379
CACHE_TTL=120

# OpenTelemetry Configuration
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_EXPORTER_OTLP_INSECURE=true
OTEL_DEPLOYMENT_ENVIRONMENT=local
